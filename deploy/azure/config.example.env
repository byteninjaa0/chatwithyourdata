# Azure Container Apps deployment config.
# Copy to config.env and fill in your values:
#   cp deploy/azure/config.example.env deploy/azure/config.env
#
# Many secrets can be copied from repo-root .env (same keys). See README below.

# ── Azure resource names (YOU create these — not from .env) ───────────────────
# AZURE_RESOURCE_GROUP  — any name you like, e.g. rg-chatwithyourdata
#                         Created by: az group create --name ... --location ...
#
# AZURE_LOCATION          — Azure region, e.g. eastus, centralindia
#                         Pick near your users: https://azure.microsoft.com/explore/global-infrastructure/geographies/
#
# AZURE_ACR_NAME          — Container Registry name (GLOBALY UNIQUE, lowercase, no hyphens)
#                         e.g. chatwithyourdataacr — if taken, try chatwithyourdatask or similar
#                         Created automatically by deploy.ps1
#
# AZURE_CONTAINERAPPS_ENV — Container Apps environment name, e.g. cae-chatwithyourdata
# AZURE_LOG_ANALYTICS     — Log Analytics workspace name, e.g. law-chatwithyourdata
#
# APP_BACKEND / APP_AGENT / APP_WEB — container app names inside the environment (your choice)
# IMAGE_TAG               — Docker tag for each deploy, e.g. v1, v2

AZURE_RESOURCE_GROUP=rg-chatwithyourdata
AZURE_LOCATION=eastus
AZURE_ACR_NAME=chatwithyourdataacr
AZURE_CONTAINERAPPS_ENV=cae-chatwithyourdata
AZURE_LOG_ANALYTICS=law-chatwithyourdata

APP_BACKEND=ca-backend
APP_AGENT=ca-agent
APP_WEB=ca-web

IMAGE_TAG=v1

# ── Azure OpenAI (copy from repo-root .env) ───────────────────────────────────
# HOW TO GET (if not already in .env):
#   1. Azure Portal → Create resource → "Azure OpenAI"
#   2. After deploy: Azure OpenAI Studio → Deployments → note deployment name (e.g. gpt-4o)
#   3. Azure Portal → your OpenAI resource → Keys and Endpoint
#      - Endpoint  → AZURE_OPENAI_ENDPOINT  (also AZURE_API_BASE in .env)
#      - Key 1     → AZURE_OPENAI_API_KEY   (also AZURE_API_KEY in .env)
#   4. API version → use OPENAI_API_VERSION or AZURE_API_VERSION from .env
#
# Maps from .env:
#   AZURE_OPENAI_ENDPOINT     ← AZURE_OPENAI_ENDPOINT (or AZURE_API_BASE)
#   AZURE_OPENAI_API_KEY      ← AZURE_OPENAI_API_KEY (or AZURE_API_KEY)
#   AZURE_OPENAI_DEPLOYMENT_NAME ← AZURE_OPENAI_DEPLOYMENT_NAME (or AZURE_DEPLOYMENT_NAME)
#   AZURE_API_VERSION         ← OPENAI_API_VERSION (or AZURE_API_VERSION)

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_API_VERSION=2024-08-01-preview

# ── Airtable (copy from repo-root .env) ───────────────────────────────────────
# HOW TO GET:
#   1. https://airtable.com/create/tokens → Create personal access token
#      Scopes: data.records:read (minimum for this app)
#      → AIRTABLE_TOKEN
#   2. Open your base in browser — URL looks like:
#      https://airtable.com/appXXXXXXXXXXXXXX/...
#      → AIRTABLE_BASE_ID = the appXXXXXXXXXXXXXX part
#   3. Table name as shown in Airtable UI → AIRTABLE_TABLE (default: "Table 1")

AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Table 1
AIRTABLE_TOKEN=

# ── Tavily (copy from repo-root .env) ─────────────────────────────────────────
# HOW TO GET:
#   1. https://tavily.com → Sign up → Dashboard → API Keys
#   → TAVILY_API_KEY

TAVILY_API_KEY=

# ── CopilotKit (do not change unless you changed agent/main.py) ───────────────
NEXT_PUBLIC_LANGGRAPH_AGENT_ID=dashboard_agent
