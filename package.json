{
  "name": "copilotkit-chat-with-your-data",
  "version": "1.0.0",
  "private": true,
  "description": "AI dashboard assistant powered by CopilotKit — ask questions about your data in natural language.",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "start:app": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:agent": "cd agent && python -m pytest tests -q",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "deploy:azure": "powershell -NoProfile -ExecutionPolicy Bypass -File ./deploy/azure/deploy.ps1"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.36",
    "@copilotkit/react-core": "^1.57.1",
    "@copilotkit/react-ui": "^1.57.1",
    "@copilotkit/runtime": "^1.57.1",
    "@hookform/resolvers": "^4.1.2",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@tavily/core": "^0.3.1",
    "@tremor/react": "^3.18.7",
    "ai": "^6.0.104",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.476.0",
    "next": "^15.5.18",
    "next-themes": "^0.4.6",
    "openai": "^4.85.1",
    "react": "^19.0.0",
    "react-day-picker": "8.10.1",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
